<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activitis.RegistreActivity">

    <!-- FONDO -->
    <ImageView
        android:id="@+id/imgFondo"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:alpha="0.3"
        android:scaleType="centerCrop"
        android:src="@drawable/img_fondo"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <!-- TEXT VIEW -->
    <TextView
        android:id="@+id/tvFooterRegistre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="70dp"
        android:text="SimaGrow - 2025 "
        android:textStyle="bold"
        android:textColor="@color/secundario"
        android:textSize="16sp"
        android:textAlignment="center"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <TextView
        android:id="@+id/tvRegistre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="700dp"
        android:text="Registro"
        android:textAlignment="center"
        android:textColor="@color/principalBoton"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.111"
        tools:layout_editor_absoluteX="16dp" />

    <!-- EDIT TEXT -->
    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etNombreRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"
        android:hint="Nombre completo"
        app:layout_constraintTop_toBottomOf="@id/tvRegistre"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etNiaRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"
        android:hint="Nia"
        app:layout_constraintTop_toBottomOf="@+id/etNombreRegistro"
        tools:layout_editor_absoluteX="0dp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etPasswordRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="50dp"
        android:layout_marginEnd="50dp"
        android:hint="Contraseña"
        app:layout_constraintTop_toBottomOf="@+id/etNiaRegistro"
        tools:layout_editor_absoluteX="48dp" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/etConfirmarPasswordRegistro"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="50dp"
        android:layout_marginStart="50dp"
        android:hint="Confirmar Contraseña"
        app:layout_constraintTop_toBottomOf="@+id/etPasswordRegistro"
        tools:layout_editor_absoluteX="48dp" />

    <!-- BOTONES -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVolverInicioSesion"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginStart="50dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="50dp"
        android:text="Volver"
        android:backgroundTint="@color/principalBoton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.972"
        app:layout_constraintStart_toEndOf="@+id/btnCrearCuentaRegistro"
        app:layout_constraintTop_toBottomOf="@+id/etConfirmarPasswordRegistro" />


    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCrearCuentaRegistro"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_marginStart="48dp"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/principalBoton"
        android:text="Crear Cuenta"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/etConfirmarPasswordRegistro" />


</androidx.constraintlayout.widget.ConstraintLayout>